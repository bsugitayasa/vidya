generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nama      String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
}

model KonfigurasiAplikasi {
  id        Int      @id @default(autoincrement())
  kunci     String   @unique
  nilai     String
  label     String
  updatedAt DateTime @updatedAt
}

model ProgramAjahan {
  id                 Int            @id @default(autoincrement())
  kode               String         @unique
  nama               String
  deskripsi          String?
  puniaNormal        Int
  puniaPasangan      Int?
  isPasanganTersedia Boolean        @default(false)
  isAktif            Boolean        @default(true)
  urutan             Int            @default(0)
  mataKuliahs        MataKuliah[]
  sisyaPrograms      SisyaProgram[]
}

model SisyaProgram {
  id              Int           @id @default(autoincrement())
  sisyaId         Int
  programAjahanId Int
  isPasangan      Boolean       @default(false)
  puniaProgram    Int
  nomorRegistrasi String?
  createdAt       DateTime      @default(now())
  programAjahan   ProgramAjahan @relation(fields: [programAjahanId], references: [id])
  sisya           Sisya         @relation(fields: [sisyaId], references: [id])

  @@unique([sisyaId, programAjahanId])
}

model Sisya {
  id                  Int              @id @default(autoincrement())
  nomorPendaftaran    String           @unique
  namaLengkap         String
  tempatLahir         String
  tanggalLahir        DateTime
  jenisKelamin        JenisKelamin
  alamat              String
  noHp                String
  email               String?
  namaGriya           String
  namaDesa            String
  totalPunia          Int
  totalTerbayar       Int              @default(0)
  statusPembayaran    StatusPembayaran @default(MENUNGGU_PEMBAYARAN)
  fileIdentitasPath   String?
  fileFotoPath        String?
  fileRekomendasiPath String?
  status              StatusSisya      @default(PENDING)
  tanggalDiksan       DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  absensiSisyas       AbsensiSisya[]
  pembayarans         Pembayaran[]
  programSisyas       SisyaProgram[]
}

model Pembayaran {
  id           Int              @id @default(autoincrement())
  sisyaId      Int
  nominal      Int              @default(0)
  buktiPath    String
  status       StatusVerifikasi @default(MENUNGGU)
  keterangan   String?
  tanggalBayar DateTime         @default(now())
  verifiedAt   DateTime?
  createdAt    DateTime         @default(now())
  sisya        Sisya            @relation(fields: [sisyaId], references: [id])
}

model MataKuliah {
  id              Int           @id @default(autoincrement())
  kode            String        @unique
  nama            String
  sks             Int
  semester        Int
  programAjahanId Int
  programAjahan   ProgramAjahan @relation(fields: [programAjahanId], references: [id])
  sesiAbsensis    SesiAbsensi[]
}

model SesiAbsensi {
  id            Int            @id @default(autoincrement())
  mataKuliahId  Int
  tanggal       DateTime
  pertemuan     Int
  topik         String?
  createdAt     DateTime       @default(now())
  absensiSisyas AbsensiSisya[]
  mataKuliah    MataKuliah     @relation(fields: [mataKuliahId], references: [id])
}

model AbsensiSisya {
  id            Int           @id @default(autoincrement())
  sesiAbsensiId Int
  sisyaId       Int
  status        StatusAbsensi
  keterangan    String?
  createdAt     DateTime      @default(now())
  sesiAbsensi   SesiAbsensi   @relation(fields: [sesiAbsensiId], references: [id])
  sisya         Sisya         @relation(fields: [sisyaId], references: [id])

  @@unique([sesiAbsensiId, sisyaId])
}

enum Role {
  ADMIN
  STAFF
}

enum StatusVerifikasi {
  MENUNGGU
  VERIFIKASI
  DITOLAK
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusSisya {
  PENDING
  AKTIF
  MEDIKSA
  TIDAK_AKTIF
}

enum StatusPembayaran {
  MENUNGGU_PEMBAYARAN
  MENUNGGU_VERIFIKASI
  BELUM_LUNAS
  LUNAS
  DITOLAK
}

enum StatusAbsensi {
  HADIR
  IZIN
  SAKIT
  ALPHA
}
